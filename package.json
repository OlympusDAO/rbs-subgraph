{
  "name": "rbs-subgraph",
  "version": "1.0.0",
  "description": "Subgraph to track RBS events",
  "main": "index.js",
  "author": "Jem <0x0xjem@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/OlympusDAO/rbs-subgraph",
  "scripts": {
    "codegen": "rm -rf generated/ && graph codegen && pnpm exec eslint --config ./.eslintrc.json --fix generated/",
    "build": "graph build",
    "lint": "eslint --config ./.eslintrc.json src --fix",
    "lint:check": "eslint --config ./.eslintrc.json src",
    "deploy:studio": "source .subgraph-version && source .env && graph deploy --version-label $SUBGRAPH_VERSION --deploy-key $GRAPH_STUDIO_TOKEN olympus-rbs",
    "test": "graph test --version 0.5.3",
    "test:force": "yarn test --recompile",
    "auth:studio": "source .env && graph auth $GRAPH_STUDIO_TOKEN",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@graphprotocol/graph-cli": "^0.98.0",
    "@graphprotocol/graph-ts": "^0.38.0",
    "assemblyscript-json": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@typescript-eslint/eslint-plugin": "^5.26.0",
    "@typescript-eslint/parser": "^5.26.0",
    "assemblyscript": "0.19.10",
    "eslint": "^8.16.0",
    "eslint-plugin-simple-import-sort": "^8.0.0",
    "matchstick-as": "^0.6.0",
    "prettier": "^2.6.2",
    "typescript": "^4.6.4"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "pnpm": "10.33.0",
    "npm": "use-pnpm",
    "yarn": "use-pnpm"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1",
      "@pnpm/npm-conf": ">=3.0.2",
      "@pnpm/npm-conf@<3.0.2": ">=3.0.2",
      "@isaacs/brace-expansion": ">=5.0.1",
      "ajv": "6.14.0",
