{
  "name": "rbs-subgraph",
  "version": "1.0.0",
  "description": "Subgraph to track RBS events",
  "main": "index.js",
  "author": "Jem <0x0xjem@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/OlympusDAO/rbs-subgraph",
  "scripts": {
    "codegen": "rm -rf generated/ && graph codegen && eslint --fix --ext .ts generated",
    "build": "graph build",
    "lint": "eslint --fix --ext .ts src generated",
    "lint:check": "eslint --max-warnings 0 --ext .ts src generated",
    "deploy:studio": "source .subgraph-version && source .env && graph deploy --version-label $SUBGRAPH_VERSION --deploy-key $GRAPH_STUDIO_TOKEN olympus-rbs",
    "test": "graph test --version 0.5.3",
    "test:force": "yarn test --recompile",
    "auth:studio": "source .env && graph auth $GRAPH_STUDIO_TOKEN",
    "preinstall": "npx only-allow@1.2.2 pnpm"
  },
  "dependencies": {
    "@graphprotocol/graph-cli": "^0.98.1",
    "@graphprotocol/graph-ts": "^0.38.0",
    "assemblyscript-json": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@typescript-eslint/eslint-plugin": "^5.26.0",
    "@typescript-eslint/parser": "^5.26.0",
    "assemblyscript": "0.19.10",
    "eslint": "^8.16.0",
    "eslint-plugin-simple-import-sort": "^8.0.0",
    "matchstick-as": "^0.6.0",
    "prettier": "^2.6.2",
    "typescript": "^4.6.4"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.33.0",
    "npm": "use-pnpm",
    "yarn": "use-pnpm"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion": "^5.0.1",
      "@pnpm/npm-conf": "^3.0.2",
      "ajv": "6.14.0",
      "axios": "^1.15.2",
      "brace-expansion": "^2.0.3",
      "cross-spawn": "^7.0.5",
      "ejs": "^3.1.10",
      "flatted": "^3.4.2",
      "follow-redirects": "^1.16.0",
      "glob": "^11.1.0",
      "immutable": "^5.1.5",
      "js-yaml": "^4.1.1",
      "lodash": "^4.18.0",
      "lodash.trim": "4.18.0",
      "lodash.trimend": "4.18.0",
      "minimatch": "^10.2.3",
      "picomatch": "^4.0.4",
      "semver": "^7.5.2",
      "tmp@<=0.2.3": "^0.2.4",
      "undici@<5.29.0": "^5.29.0",
      "undici@>=6.0.0 <6.24.0": "^6.24.0",
      "undici@>=7.0.0 <7.24.0": "^7.24.0",
      "word-wrap": "^1.2.4",
      "yaml": "^2.8.3"
    }
  }
}
